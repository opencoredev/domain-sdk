{
  "name": "@opencoredev/domain-sdk",
  "version": "0.1.0",
  "description": "Add, verify, monitor, and remove customer domains with one TypeScript API.",
  "keywords": [
    "cloudflare",
    "custom-domains",
    "netlify",
    "railway",
    "render",
    "typescript",
    "vercel"
  ],
  "homepage": "https://domain-sdk.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/opencoredev/domain-sdk.git"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./vercel": {
      "types": "./dist/providers/vercel/index.d.ts",
      "import": "./dist/providers/vercel/index.js"
    },
    "./cloudflare": {
      "types": "./dist/providers/cloudflare/index.d.ts",
      "import": "./dist/providers/cloudflare/index.js"
    },
    "./railway": {
      "types": "./dist/providers/railway/index.d.ts",
      "import": "./dist/providers/railway/index.js"
    },
    "./render": {
      "types": "./dist/providers/render/index.d.ts",
      "import": "./dist/providers/render/index.js"
    },
    "./netlify": {
      "types": "./dist/providers/netlify/index.d.ts",
      "import": "./dist/providers/netlify/index.js"
    },
    "./testing": {
      "types": "./dist/testing/index.d.ts",
      "import": "./dist/testing/index.js"
    }
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "rm -rf dist && bun run build:js && bun run build:types",
    "build:js": "bun build src/index.ts src/providers/vercel/index.ts src/providers/cloudflare/index.ts src/providers/railway/index.ts src/providers/render/index.ts src/providers/netlify/index.ts src/testing/index.ts --root src --outdir dist --target node --format esm --sourcemap=external --splitting --entry-naming '[dir]/[name].[ext]'",
    "build:types": "tsc -p tsconfig.build.json",
    "check-types": "tsc --noEmit",
    "lint": "oxlint src test",
    "test": "bun test"
  },
  "dependencies": {
    "tldts": "^7.0.19"
  },
  "devDependencies": {
    "@domain-sdk/config": "workspace:*",
    "@types/bun": "^1.3.8",
    "@types/node": "^22.13.14",
    "oxlint": "^1.72.0",
    "typescript": "^6.0.0"
  },
  "engines": {
    "node": ">=20"
  }
}
