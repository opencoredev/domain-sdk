{
  "name": "fumadocs",
  "version": "0.0.4",
  "private": true,
  "scripts": {
    "build": "next build",
    "dev": "bun run scripts/stop-stale-next-dev.ts && PORTLESS_PORT=1355 portless run --name domain-sdk --force next dev",
    "start": "serve out",
    "check-types": "fumadocs-mdx && next typegen && tsc --noEmit",
    "postinstall": "fumadocs-mdx",
    "lint": "oxlint",
    "test": "bun test --pass-with-no-tests"
  },
  "dependencies": {
    "@gsap/react": "^2.1.2",
    "@hugeicons/core-free-icons": "^4.2.2",
    "@hugeicons/react": "^1.1.9",
    "@opencoredev/domain-sdk": "workspace:*",
    "@orama/orama": "^3.1.18",
    "cnfast": "^0.0.8",
    "fumadocs-core": "16.11.3",
    "fumadocs-mdx": "15.1.0",
    "fumadocs-ui": "npm:@fumadocs/base-ui@16.11.3",
    "gsap": "^3.15.0",
    "next": "16.2.10",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.2",
    "@types/mdx": "^2.0.14",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "oxlint": "^1.73.0",
    "portless": "^0.15.1",
    "postcss": "^8.5.16",
    "serve": "^14.2.6",
    "tailwindcss": "^4.3.2",
    "typescript": "^6.0.3"
  }
}
